{
  "name": "apple-books-mcp",
  "version": "0.1.0",
  "description": "MCP server for Apple Books with read and write support",
  "author": "Raghib Hasan",
  "license": "MIT",
  "keywords": [
    "mcp",
    "apple-books",
    "annotations",
    "highlights",
    "model-context-protocol"
  ],
  "module": "src/index.ts",
